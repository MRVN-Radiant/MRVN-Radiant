<!-- TODO: model="models/editor/playerstart.mdl" -->
<point name="info_player_start" color=".3 .3 1" box="-16 -16 0 16 16 72" model="models/editor/playerstart.obj">
Used for spawning player when match starts.
-------- KEYS --------
<integer key="teamnum" name="Team number" value="-1">TEAM_ANY = -1; TEAM_BOTH = 4; TEAM_MILITIA = 3, TEAM_IMC = 2</integer>
<targetname key="targetname" name="Target Name" value="spawn_">UNIQUE Target name</targetname>
<angles key="angles" name="Pitch Yaw Roll" value="0 0 0">Individual control of PITCH, YAW, and ROLL.</angles>
<boolean key="gamemode_at" name="gamemode_at" value="0">Use this for Attrition?</boolean>
<boolean key="gamemode_cp" name="gamemode_cp" value="0">Use this for Hardpoint domination?</boolean>
<boolean key="gamemode_ctf" name="gamemode_ctf" value="0">Use this for Capture the flag?</boolean>
<boolean key="gamemode_ctfp" name="gamemode_ctfp" value="0">Use this for Capture the flag pro?</boolean>
<boolean key="gamemode_mfd" name="gamemode_mfd" value="0">Use this for Marked for death?</boolean>
<boolean key="gamemode_mfdp" name="gamemode_mfdp" value="0">Use this for Marked for death pro?</boolean>
<boolean key="gamemode_lts" name="gamemode_lts" value="0">Use this for Last Titan standing?</boolean>
<boolean key="gamemode_wlts" name="gamemode_wlts" value="0">Use this for Wingman LTS?</boolean>
<boolean key="gamemode_ps" name="gamemode_ps" value="0">Use this for Pilot skirmish?</boolean>
<boolean key="gamemode_tdm" name="gamemode_tdm" value="0">Use this for Pilot hunter?</boolean>
<boolean key="gamemode_ffa" name="gamemode_ffa" value="0">Use this for Free for all?</boolean>
<boolean key="gamemode_scv" name="gamemode_scv" value="0">Use this for Scavenger?</boolean>
-------- NOTES --------
Place slightly above the ground to avoid getting stuck in the floor.
</point>

